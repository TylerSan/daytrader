__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
config/user.yaml
data/db/*.db
data/state.db
data/tick/
data/imports/
data/exports/
data/cache/
data/locks/
.pytest_cache/

# Journal subsystem: user-authored contract + setups are not tracked.
# The example YAML stays in the repo as a format reference.
docs/trading/Contract.md
docs/trading/setups/*.yaml
!docs/trading/setups/example_*.yaml

# Secrets — never commit
config/secrets.yaml

# launchd run logs (rotate manually for now; auto-rotate in future phase)
data/logs/launchd/*.out
data/logs/launchd/*.err
data/logs/launchd/premarket-*.log
data/logs/launchd/weekly-*.log
!data/logs/launchd/.gitkeep
